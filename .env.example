# ===================================================================
# STABLEPAY ENVIRONMENT VARIABLES
# ===================================================================
# IMPORTANT: Never commit the actual .env file to version control!
# Copy this file to .env and fill in your actual values.
# ===================================================================

# Database - Supabase PostgreSQL
# Get these from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/database"

# Supabase Credentials
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS - Allowed Origins (comma-separated)
# Add your production domain here
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# TESTNET Configuration (for development/testing)
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
ETHEREUM_SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"

# USDC Testnet Contract Addresses (do not change)
USDC_BASE_SEPOLIA="0x036CbD53842c5426634e7929541eC2318f3dCF7e"
USDC_ETHEREUM_SEPOLIA="0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238"

# Payment Addresses - Your wallet addresses for receiving payments
PAYMENT_ADDRESS_BASE_SEPOLIA="0xYOUR_WALLET_ADDRESS_HERE"
PAYMENT_ADDRESS_ETHEREUM_SEPOLIA="0xYOUR_WALLET_ADDRESS_HERE"

# Private Key (optional - for automated blockchain scanning)
# ⚠️  CRITICAL: Never commit this value! Leave empty in this file.
PRIVATE_KEY=""

# Security Secrets
# Generate these with: node scripts/generate-secrets.js
# Or use: openssl rand -base64 32
JWT_SECRET=""
ADMIN_PASSWORD=""

# Webhook Retry Cron (Vercel cron authentication)
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ===================================================================
# MAINNET RPC URLs (scanner requires these)
# ===================================================================
BASE_MAINNET_RPC_URL="https://mainnet.base.org"
ETHEREUM_MAINNET_RPC_URL="https://eth.llamarpc.com"
POLYGON_MAINNET_RPC_URL="https://polygon-rpc.com"
ARBITRUM_MAINNET_RPC_URL="https://arb1.arbitrum.io/rpc"
BNB_MAINNET_RPC_URL="https://bsc-dataseed.binance.org"
SOLANA_MAINNET_RPC_URL="https://api.mainnet-beta.solana.com"

# TRON — required only if accepting TRC-20 payments
TRONGRID_API_KEY=""

# ===================================================================
# PUBLIC URL — used for links in emails, receipts, and Stablo system prompt
# ===================================================================
# Override to your production domain (no trailing slash).
BASE_URL="https://wetakestables.shop"

# ===================================================================
# ADMIN ACCESS
# ===================================================================
# The bearer token admins present (also honored in requireAdminKey middleware).
# DB-stored admin_password will be silently upgraded to a bcrypt hash on first successful login.
ADMIN_KEY=""
ADMIN_EMAIL=""

# ===================================================================
# EMAIL (Resend)
# Get keys from https://resend.com/api-keys
# ===================================================================
RESEND_API_KEY=""
FROM_EMAIL="StablePay <hello@wetakestables.shop>"

# ===================================================================
# STABLO AI AGENT
# Get key from https://console.anthropic.com/
# ===================================================================
ANTHROPIC_API_KEY=""

# Agent wallet — for managed-wallet refunds + gas sponsorship
# EVM keypair handles Base/Ethereum/Polygon/Arbitrum/BNB
AGENT_WALLET_ADDRESS=""
AGENT_WALLET_KEY=""
# Solana keypair (base58 private key or JSON array)
AGENT_SOLANA_ADDRESS=""
AGENT_SOLANA_KEY=""