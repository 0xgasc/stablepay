{
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/checkout-widget.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "max-age=60" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing.html"
    },
    {
      "source": "/enterprise-admin",
      "destination": "/enterprise-admin.html"
    },
    {
      "source": "/checkout",
      "destination": "/crypto-pay.html"
    },
    {
      "source": "/api/cron/:path*",
      "destination": "/api/cron/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/health/:path*",
      "destination": "/api"
    }
  ]
}
